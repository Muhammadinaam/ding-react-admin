{
  "name": "ding-react-admin",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "description": "Composable admin shell (Ant Design + React Router): quick-start AdminApp or build your own layout.",
  "repository": {
    "type": "git",
    "url": "https://github.com/Muhammadinaam/ding-react-admin.git"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "vite build",
    "dev:example": "yarn --cwd examples/playground dev",
    "build:example": "yarn --cwd examples/playground build",
    "prepublishOnly": "yarn build"
  },
  "peerDependencies": {
    "@ant-design/icons": ">=5",
    "antd": ">=5",
    "react": ">=18",
    "react-dom": ">=18",
    "react-router-dom": ">=6"
  },
  "devDependencies": {
    "@ant-design/icons": "^5.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "antd": "^5.24.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2",
    "typescript": "~6.0.2",
    "vite": "^8.0.9",
    "vite-plugin-dts": "^4.5.4"
  }
}
